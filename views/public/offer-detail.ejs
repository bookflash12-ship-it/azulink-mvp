<%- include('../partials/header') %>

<div class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/">Accueil</a></li>
      <li class="breadcrumb-item"><a href="/catalogue">Catalogue</a></li>
      <li class="breadcrumb-item active"><%= offer.title %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <div class="col-lg-8">
      <img id="mainOfferImage" src="<%= offer.images[0] %>" class="w-100 rounded-4 mb-2" style="height:380px; object-fit:cover;" alt="<%= offer.title %>">
      <% if (offer.images.length > 1) { %>
        <div class="d-flex gap-2 mb-4 flex-wrap">
          <% offer.images.forEach(img => { %>
            <img src="<%= img %>" class="gallery-thumb" alt="miniature">
          <% }) %>
        </div>
      <% } %>

      <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
          <span class="badge bg-success mb-2"><%= category ? category.name : '' %></span>
          <h1 class="h2"><%= offer.title %></h1>
          <p class="text-muted"><i class="bi bi-geo-alt"></i> <%= offer.location.address %> &nbsp; · &nbsp; <i class="bi bi-clock"></i> <%= offer.duration %></p>
        </div>
        <% if (currentUser && currentUser.role === 'traveler') { %>
          <form method="post" action="/mon-compte/favoris/<%= offer.id %>">
            <button class="btn btn-azulink-outline">
              <i class="bi <%= isFavorite ? 'bi-heart-fill' : 'bi-heart' %>"></i> <%= isFavorite ? 'Dans vos favoris' : 'Ajouter aux favoris' %>
            </button>
          </form>
        <% } %>
      </div>

      <p class="mt-3"><%= offer.description %></p>

      <h4 class="section-title mt-4">Programme détaillé</h4>
      <p style="white-space: pre-line;"><%= offer.program %></p>

      <h4 class="section-title mt-4">Ce qui est inclus</h4>
      <ul>
        <% offer.included.forEach(item => { %><li><%= item %></li><% }) %>
      </ul>

      <h4 class="section-title mt-4">Informations pratiques</h4>
      <p><%= offer.practicalInfo %></p>

      <h4 class="section-title mt-4">Localisation</h4>
      <div id="map"></div>

      <button class="btn btn-azulink-outline mt-4 btn-download-offline"
        data-trip='<%- JSON.stringify({id: offer.id, title: offer.title, address: offer.location.address, duration: offer.duration, program: offer.program}) %>'>
        <i class="bi bi-download"></i> Télécharger pour hors-ligne
      </button>
    </div>

    <div class="col-lg-4">
      <div class="stat-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="price-tag fs-4"><%= offer.price %> MAD</span>
          <span class="text-muted small">/ personne</span>
        </div>
        <form method="post" action="/offres/<%= offer.slug %>/reserver">
          <div class="mb-2">
            <label class="form-label small">Nom complet *</label>
            <input type="text" name="fullName" class="form-control" required value="<%= currentUser ? currentUser.name : '' %>">
          </div>
          <div class="mb-2">
            <label class="form-label small">Téléphone *</label>
            <input type="tel" name="phone" class="form-control" required value="<%= currentUser ? currentUser.phone : '' %>">
          </div>
          <div class="mb-2">
            <label class="form-label small">Email *</label>
            <input type="email" name="email" class="form-control" required value="<%= currentUser ? currentUser.email : '' %>">
          </div>
          <div class="mb-2">
            <label class="form-label small">Date souhaitée *</label>
            <input type="date" name="date" class="form-control" required>
          </div>
          <div class="mb-2">
            <label class="form-label small">Nombre de participants *</label>
            <input type="number" name="participants" min="1" value="1" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label small">Commentaires</label>
            <textarea name="comments" class="form-control" rows="2"></textarea>
          </div>
          <button type="submit" class="btn btn-azulink-primary w-100"><i class="bi bi-calendar-check"></i> Demander une réservation</button>
          <p class="small text-muted mt-2 mb-0">Votre demande sera transmise au prestataire et à notre équipe pour confirmation.</p>
        </form>
      </div>

      <% if (provider) { %>
        <div class="provider-strip">
          <h6><i class="bi bi-shop"></i> Prestataire</h6>
          <p class="fw-bold mb-1"><%= provider.businessName %></p>
          <p class="small text-muted mb-1"><%= provider.type %></p>
          <p class="small mb-0"><%= provider.description %></p>
        </div>
      <% } %>
    </div>
  </div>

  <% if (similar.length) { %>
    <h4 class="section-title mt-5 mb-3">Expériences similaires</h4>
    <div class="row g-4">
      <% similar.forEach(o => { %>
        <div class="col-md-4">
          <div class="offer-card">
            <img src="<%= o.images[0] %>" class="offer-img" alt="<%= o.title %>">
            <div class="p-3">
              <h6><%= o.title %></h6>
              <div class="d-flex justify-content-between align-items-center">
                <span class="price-tag small"><%= o.price %> MAD</span>
                <a href="/offres/<%= o.slug %>" class="btn btn-sm btn-azulink-outline">Voir</a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var map = L.map('map').setView([<%= offer.location.lat %>, <%= offer.location.lng %>], 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    L.marker([<%= offer.location.lat %>, <%= offer.location.lng %>]).addTo(map)
      .bindPopup(<%- JSON.stringify(offer.title) %>).openPopup();
  });
</script>

<%- include('../partials/footer') %>
