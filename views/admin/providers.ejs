<%- include('../partials/header') %>
<div class="container py-4">
  <h1 class="h3 mb-4">Prestataires</h1>
  <div class="row g-4">
    <div class="col-lg-3"><%- include('../partials/admin-sidebar') %></div>
    <div class="col-lg-9">
      <% providers.forEach(p => { %>
        <div class="stat-card mb-3">
          <div class="d-flex justify-content-between flex-wrap gap-2">
            <div>
              <h6 class="mb-1"><%= p.businessName %> <span class="badge badge-status-<%= p.validated ? 'validated' : 'pending' %>"><%= p.validated ? 'Validé' : 'En attente' %></span></h6>
              <p class="small text-muted mb-1"><%= p.type %> · <%= p.offersCount %> offre(s)</p>
              <p class="small mb-0"><%= p.description %></p>
              <p class="small text-muted mb-0"><i class="bi bi-telephone"></i> <%= p.phone %> · <i class="bi bi-envelope"></i> <%= p.email %></p>
            </div>
            <div class="d-flex align-items-start gap-2">
              <% if (!p.validated) { %>
                <form method="post" action="/admin/prestataires/<%= p.id %>/valider">
                  <button class="btn btn-sm btn-azulink-primary">Valider</button>
                </form>
              <% } else { %>
                <form method="post" action="/admin/prestataires/<%= p.id %>/suspendre">
                  <button class="btn btn-sm btn-outline-danger">Suspendre</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
