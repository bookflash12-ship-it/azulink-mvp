<%- include('../partials/header') %>
<div class="container py-4">
  <h1 class="h3 mb-4">Utilisateurs</h1>
  <div class="row g-4">
    <div class="col-lg-3"><%- include('../partials/admin-sidebar') %></div>
    <div class="col-lg-9">
      <div class="stat-card p-0">
        <table class="table mb-0">
          <thead><tr><th>Nom</th><th>Email</th><th>Rôle</th><th>Inscrit le</th><th></th></tr></thead>
          <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td><span class="badge bg-secondary"><%= u.role %></span></td>
              <td class="small text-muted"><%= new Date(u.createdAt).toLocaleDateString('fr-FR') %></td>
              <td>
                <% if (u.id !== currentUser.id) { %>
                  <form method="post" action="/admin/utilisateurs/<%= u.id %>/supprimer" onsubmit="return confirm('Supprimer cet utilisateur ?');">
                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
